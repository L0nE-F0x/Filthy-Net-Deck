node_modules
dist
src-tauri/target
.DS_Store
*.log
!src-tauri/tests/fixtures/logs/*.log
.env
.env.*
.vscode
.idea
*.local

# Installers must never live in the app's public dir — Vite copies public/ into
# the bundle, which recursively inflates every installer. Site downloads live in
# website/downloads/ instead.
public/downloads/

# Tauri updater signing keys — never commit these
*.key
*.key.pub

# Remotion marketing video — source is committed, renders / audio artifacts are not
marketing-video/out/
marketing-video/.remotion/
marketing-video/public/*.wav

